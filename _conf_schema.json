{
  "SESSDATA": {
    "description": "B站 Cookie SESSDATA（登录后获取）",
    "type": "str",
    "default": "",
    "hint": "浏览器登录B站后，从Cookie中复制"
  },
  "BILI_JCT": {
    "description": "B站 Cookie bili_jct（CSRF Token）",
    "type": "str",
    "default": "",
    "hint": "浏览器登录B站后，从Cookie中复制"
  },
  "DEDE_USER_ID": {
    "description": "Bot的B站UID（DedeUserID）",
    "type": "str",
    "default": "",
    "hint": "浏览器登录B站后，从Cookie中复制"
  },
  "REFRESH_TOKEN": {
    "description": "B站 refresh_token（用于Cookie自动刷新）",
    "type": "str",
    "default": "",
    "hint": "登录时从 localStorage 的 ac_time_value 获取"
  },
  "OWNER_MID": {
    "description": "主人的B站UID（好感度特殊处理）",
    "type": "str",
    "default": "",
    "hint": "主人的B站数字UID"
  },
  "OWNER_NAME": {
    "description": "主人名称（用于提示词引用）",
    "type": "str",
    "default": ""
  },

  "ENABLE_REPLY": {
    "description": "启用评论自动回复",
    "type": "bool",
    "default": true
  },
  "ENABLE_PROACTIVE": {
    "description": "启用主动看视频/评论",
    "type": "bool",
    "default": true
  },
  "ENABLE_DYNAMIC": {
    "description": "启用自动发动态",
    "type": "bool",
    "default": true
  },
  "ENABLE_AFFECTION": {
    "description": "启用好感度系统",
    "type": "bool",
    "default": true
  },
  "ENABLE_MOOD": {
    "description": "启用心情系统",
    "type": "bool",
    "default": true
  },

  "POLL_INTERVAL": {
    "description": "评论轮询间隔（秒）",
    "type": "int",
    "default": 20,
    "hint": "建议 15-60 秒，太短容易被风控"
  },
  "MAX_REPLIES_PER_RUN": {
    "description": "每轮最多回复条数",
    "type": "int",
    "default": 3
  },
  "PROACTIVE_VIDEO_COUNT": {
    "description": "每天主动看几个视频",
    "type": "int",
    "default": 3
  },
  "PROACTIVE_COMMENT_COUNT": {
    "description": "每天主动评论几条",
    "type": "int",
    "default": 2
  },
  "PROACTIVE_TIMES_COUNT": {
    "description": "每天触发几次主动行为",
    "type": "int",
    "default": 2
  },
  "SLEEP_START": {
    "description": "休眠开始时间（0-23）",
    "type": "int",
    "default": 2
  },
  "SLEEP_END": {
    "description": "休眠结束时间（0-23）",
    "type": "int",
    "default": 8
  },

  "PROACTIVE_LIKE": {
    "description": "主动点赞",
    "type": "bool",
    "default": true
  },
  "PROACTIVE_COIN": {
    "description": "主动投币",
    "type": "bool",
    "default": false
  },
  "PROACTIVE_FAV": {
    "description": "主动收藏",
    "type": "bool",
    "default": true
  },
  "PROACTIVE_FOLLOW": {
    "description": "主动关注UP主",
    "type": "bool",
    "default": true
  },
  "PROACTIVE_COMMENT": {
    "description": "主动评论",
    "type": "bool",
    "default": true
  },
  "PROACTIVE_FOLLOW_UIDS": {
    "description": "特别关注的UP主UID列表（逗号分隔）",
    "type": "str",
    "default": "",
    "hint": "多个UID用英文逗号隔开，如：12345,67890"
  },

  "COOKIE_AUTO_REFRESH": {
    "description": "Cookie过期自动刷新",
    "type": "bool",
    "default": true
  },
  "COOKIE_CHECK_INTERVAL": {
    "description": "Cookie检查间隔（小时）",
    "type": "int",
    "default": 6
  }
