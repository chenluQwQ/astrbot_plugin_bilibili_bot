{
  "LLM_PROVIDER_ID": {
    "description": "选择用于回复/记忆压缩的LLM（留空用AstrBot默认）",
    "type": "string",
    "default": "",
    "_special": "select_provider"
  },
  "SESSDATA": {
    "description": "B站 Cookie SESSDATA（/bili登录 扫码自动填入）",
    "type": "string",
    "default": ""
  },
  "BILI_JCT": {
    "description": "B站 Cookie bili_jct（扫码自动填入）",
    "type": "string",
    "default": ""
  },
  "DEDE_USER_ID": {
    "description": "Bot的B站UID（扫码自动填入）",
    "type": "string",
    "default": ""
  },
  "REFRESH_TOKEN": {
    "description": "B站 refresh_token（扫码自动填入）",
    "type": "string",
    "default": ""
  },
  "OWNER_MID": {
    "description": "主人的B站UID（好感度特殊处理）",
    "type": "string",
    "default": ""
  },
  "OWNER_NAME": {
    "description": "主人名称（用于提示词）",
    "type": "string",
    "default": ""
  },
  "OWNER_BILI_NAME": {
    "description": "主人的B站昵称（用于@推荐）",
    "type": "string",
    "default": ""
  },
  "EMBED_API_KEY": {
    "description": "Embedding API Key（记忆向量化用）",
    "type": "string",
    "default": ""
  },
  "EMBED_API_BASE": {
    "description": "Embedding API Base URL",
    "type": "string",
    "default": "https://api.siliconflow.cn/v1"
  },
  "EMBED_MODEL": {
    "description": "Embedding 模型名称",
    "type": "string",
    "default": "BAAI/bge-m3"
  },
  "VIDEO_VISION_API_KEY": {
    "description": "视频分析 视觉模型 API Key（分析视频封面+内容）",
    "type": "string",
    "default": "",
    "hint": "留空则回退为纯文本LLM分析"
  },
  "VIDEO_VISION_PROVIDER_ID": {
    "description": "视频分析使用的 AstrBot 模型提供商（留空则使用独立 API 配置）",
    "type": "string",
    "default": "",
    "_special": "select_provider"
  },
  "VIDEO_VISION_API_BASE": {
    "description": "视频分析 视觉模型 API Base URL",
    "type": "string",
    "default": "https://api.siliconflow.cn/v1"
  },
  "VIDEO_VISION_MODEL": {
    "description": "视频分析 视觉模型名称",
    "type": "string",
    "default": "",
    "hint": "如 google/gemma-3-27b-it、Pro/Qwen/Qwen2.5-VL-7B-Instruct 等"
  },
  "IMAGE_VISION_API_KEY": {
    "description": "图片识别 视觉模型 API Key（识别评论中的图片）",
    "type": "string",
    "default": "",
    "hint": "留空则不识别评论图片"
  },
  "IMAGE_VISION_PROVIDER_ID": {
    "description": "图片识别使用的 AstrBot 模型提供商（留空则使用独立 API 配置）",
    "type": "string",
    "default": "",
    "_special": "select_provider"
  },
  "IMAGE_VISION_API_BASE": {
    "description": "图片识别 视觉模型 API Base URL",
    "type": "string",
    "default": "https://api.siliconflow.cn/v1"
  },
  "IMAGE_VISION_MODEL": {
    "description": "图片识别 视觉模型名称",
    "type": "string",
    "default": "",
    "hint": "如 google/gemma-3-27b-it 等"
  },
  "IMAGE_GEN_API_KEY": {
    "description": "图片生成 API Key（动态配图用）",
    "type": "string",
    "default": "",
    "hint": "留空则复用 VIDEO_VISION_API_KEY"
  },
  "IMAGE_GEN_API_BASE": {
    "description": "图片生成 API Base URL",
    "type": "string",
    "default": "https://openrouter.ai/api/v1"
  },
  "IMAGE_GEN_MODEL": {
    "description": "图片生成模型名称",
    "type": "string",
    "default": "black-forest-labs/flux-schnell",
    "hint": "支持 Flux 系列模型"
  },
  "ENABLE_REPLY": {
    "description": "启用评论自动回复",
    "type": "bool",
    "default": true
  },
  "ENABLE_AFFECTION": {
    "description": "启用好感度系统",
    "type": "bool",
    "default": true
  },
  "ENABLE_MOOD": {
    "description": "启用心情系统",
    "type": "bool",
    "default": true
  },
  "ENABLE_PERSONALITY_EVOLUTION": {
    "description": "启用性格演化（每日反思）",
    "type": "bool",
    "default": true
  },
  "EVOLVE_HOUR": {
    "description": "性格演化触发时间（0-23点）",
    "type": "int",
    "default": 1,
    "hint": "建议设在休眠时段，如凌晨1点"
  },
  "EVOLVE_MAX_RETRIES": {
    "description": "性格演化失败后的最大重试次数",
    "type": "int",
    "default": 2,
    "hint": "默认失败 2 次后跳过当日演化"
  },
  "EVOLVE_PROMPT": {
    "description": "自定义性格演化提示词（留空用默认）",
    "type": "text",
    "default": "",
    "hint": "可用变量：{old_traits} {old_habits} {old_opinions} {recent_texts} {owner_name}。回复必须为JSON格式含 new_trait/trigger/speech_habits/opinions/reflection 字段"
  },
  "ENABLE_PROACTIVE": {
    "description": "启用主动看视频/评论",
    "type": "bool",
    "default": false
  },
  "PROACTIVE_VIDEO_COUNT": {
    "description": "每天主动看几个视频",
    "type": "int",
    "default": 3
  },
  "PROACTIVE_COMMENT_COUNT": {
    "description": "每天主动评论几条",
    "type": "int",
    "default": 2
  },
  "PROACTIVE_TIMES_COUNT": {
    "description": "每天触发几次主动行为",
    "type": "int",
    "default": 2
  },
  "PROACTIVE_FOLLOW_UIDS": {
    "description": "特别关注的UP主UID列表",
    "type": "list",
    "default": [],
    "hint": "这些UP主的新视频会优先观看"
  },
  "PROACTIVE_LIKE": {
    "description": "主动点赞（≥6分）",
    "type": "bool",
    "default": true
  },
  "PROACTIVE_COIN": {
    "description": "主动投币（≥8分）",
    "type": "bool",
    "default": false
  },
  "PROACTIVE_FAV": {
    "description": "主动收藏（≥8分）",
    "type": "bool",
    "default": true
  },
  "PROACTIVE_FOLLOW": {
    "description": "主动关注UP主（≥9分）",
    "type": "bool",
    "default": true
  },
  "PROACTIVE_COMMENT": {
    "description": "主动评论（≥7分）",
    "type": "bool",
    "default": true
  },
  "ENABLE_DYNAMIC": {
    "description": "启用自动发动态",
    "type": "bool",
    "default": false
  },
  "DYNAMIC_TIMES_COUNT": {
    "description": "每天触发几次动态发布",
    "type": "int",
    "default": 1,
    "hint": "建议 1-3 次"
  },
  "DYNAMIC_DAILY_COUNT": {
    "description": "每天最多发几条动态",
    "type": "int",
    "default": 1,
    "hint": "防止刷屏"
  },
  "DYNAMIC_TOPICS": {
    "description": "动态主题池（每行一个）",
    "type": "list",
    "default": [],
    "hint": "留空使用默认主题池"
  },
  "ENABLE_WEB_PANEL": {
    "description": "启用Web管理面板",
    "type": "bool",
    "default": false
  },
  "WEB_PANEL_PORT": {
    "description": "Web面板端口 -还在修缮，目前并非完全效果",
    "type": "int",
    "default": 5001
  },
  "WEB_PANEL_PASSWORD": {
    "description": "Web面板登录密码",
    "type": "string",
    "default": "admin123"
  },
  "POLL_INTERVAL": {
    "description": "评论轮询间隔（秒）",
    "type": "int",
    "default": 20,
    "hint": "建议 15-60 秒"
  },
  "MAX_REPLIES_PER_RUN": {
    "description": "每轮最多回复条数",
    "type": "int",
    "default": 3
  },
  "SLEEP_START": {
    "description": "休眠开始时间（0-23）",
    "type": "int",
    "default": 2
  },
  "SLEEP_END": {
    "description": "休眠结束时间（0-23）",
    "type": "int",
    "default": 8
  },
  "COOKIE_AUTO_REFRESH": {
    "description": "Cookie过期自动刷新",
    "type": "bool",
    "default": true
  },
  "COOKIE_CHECK_INTERVAL": {
    "description": "Cookie检查间隔（小时）",
    "type": "int",
    "default": 6
  },
  "USE_ASTRBOT_PERSONA": {
    "description": "使用AstrBot自带人设",
    "type": "bool",
    "default": true
  },
  "CUSTOM_SYSTEM_PROMPT": {
    "description": "自定义系统提示词（USE_ASTRBOT_PERSONA关闭时使用）",
    "type": "text",
    "default": "你是一个B站UP主的AI助手，负责回复评论。"
  },
  "REPLY_MAX_TOKENS": {
    "description": "回复最大token数",
    "type": "int",
    "default": 300
  }
}
